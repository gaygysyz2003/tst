"""
mock_switch.py — in-memory fake of the Polatis switch.

Implements the same interface app.py expects via core_backend, so the whole
app runs end-to-end with no hardware. State lives in memory and resets on
restart (timers still persist to patch_timers.json, owned by app.py).
"""
import threading

NUM_PORTS = 114

_lock = threading.Lock()
# port -> partner port (both directions stored, e.g. {5:22, 22:5})
_patches: dict[int, int] = {}


def get_patches() -> dict[int, int]:
    with _lock:
        return dict(_patches)


def get_power() -> dict[int, float | None]:
    """Deterministic pseudo-readings so the Power view looks alive.

    Patched ports report a healthy level; a few ports report None (no reading);
    the rest spread across the green/yellow/red bands by port number.
    """
    with _lock:
        patched = set(_patches)
    readings: dict[int, float | None] = {}
    for p in range(1, NUM_PORTS + 1):
        if p % 19 == 0:                      # ~6 ports with no reading
            readings[p] = None
        elif p in patched:
            readings[p] = round(-4.0 - (p % 5) * 0.7, 1)     # green band
        else:
            # fan out across bands: green / yellow / red
            readings[p] = round(-6.0 - (p % 40) * 0.9, 1)
    return readings


def mk_patch(a: int, b: int) -> None:
    with _lock:
        if a in _patches or b in _patches:
            raise RuntimeError(f"port already patched: {a if a in _patches else b}")
        _patches[a] = b
        _patches[b] = a


def dl_patch(a: int, b: int) -> None:
    with _lock:
        _patches.pop(a, None)
        _patches.pop(b, None)
